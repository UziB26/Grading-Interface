GEMINI_API_KEY=your_actual_key_here
# Optional: default is gemini-2.5-flash-lite (higher free-tier quota than gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash-lite
# Optional: cap parallel Gemini calls during async grading (default: 2)
AI_MAX_CONCURRENCY=2
# Optional: max seconds to wait per Gemini request (default: 30)
AI_REQUEST_TIMEOUT_SECONDS=30
          "benchmark": "q1_data_preparation_notes.md",
          "seed_from": "outputs/q1_data_preparation_notes.md"
        }
      ]
    },
    {
      "id": "q2",
      "label": "Question 2 - Contract summary",
      "max_mark": 10,
      "compare_mode": "csv",
      "files": [
        {
          "benchmark": "q2_contract_summary.csv",
          "seed_from": "outputs/q2_contract_summary.csv"
        }
      ]
    },
    {
      "id": "q3",
      "label": "Question 3 - Task statistics",
      "max_mark": 15,
      "compare_mode": "csv",
      "files": [

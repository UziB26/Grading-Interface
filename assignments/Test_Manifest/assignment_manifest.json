  "submission_aliases": {
    "q1_data_preparation_notes.md": [
      "q1_data_preparation_notes.md",
      "data_preparation_notes.md"
    ],
    "q2_contract_summary.csv": [
      "q2_contract_summary.csv",
      "contract_summary.csv"
    ],
    "q3_task_statistics.csv": [
      "q3_task_statistics.csv",
      "task_statistics.csv"
    ],
    "q4_waiting_entries_by_task.csv": [
      "q4_waiting_entries_by_task.csv",
      "waiting_entries_by_task.csv"
    ],
    "q5_top5_processing_time_last_week.csv": [
      "q5_top5_processing_time_last_week.csv",
      "top5_processing_time_last_week.csv"
    ],
    "contractPaths_output.csv": [
      "contractPaths_output.csv",
      "contract_paths_output.csv",
      "q6_contract_paths.csv"
    ],
    "q7_data_analysis_report.md": [
      "q7_data_analysis_report.md",
      "data_analysis_report.md"
    ],
    "workflow_queries.sql": [
      "workflow_queries.sql",
      "q8_workflow_queries.sql"
    ],
    "yieldx_transform.xsl": [
      "yieldx_transform.xsl",
      "yieldx_transform.xslt",
      "transform.xsl"
    ],
    "futures_price_generated.xml": [
      "futures_price_generated.xml",
      "futures_price.xml",
      "output.xml"
    ]
  },
  "code_checks": {
    ".py": {
      "engine": "ast",
      "rules": [
        {
          "label": "pandas import",
          "type": "import_module",
          "modules": ["pandas"]
        },
        {
          "label": "timestamp parsing",
          "type": "token_match",
          "tokens": ["ts_time_long", "status_time_long", "to_datetime"]
        },
        {
          "label": "wait time logic",
          "type": "token_match",
          "tokens": ["wait_time", "wait_time_ms"]
        },
        {
          "label": "processing time logic",
          "type": "token_match",
          "tokens": ["processing_time", "processing_time_ms"]
        },
        {
          "label": "throughput logic",
          "type": "token_match",
          "tokens": ["throughput", "throughput_per_second", "throughput_per_minute"]
        },
        {
          "label": "contract summary",
          "type": "token_match",
          "tokens": ["fc_ctype", "contract_summary", "question_2", "question_2_contract_summary"]
        },
        {
          "label": "task statistics",
          "type": "token_match",
          "tokens": ["task_statistics", "question_3", "question_3_task_statistics"]
        },
        {
          "label": "contract paths",
          "type": "token_match",
          "tokens": ["contractpaths", "contract_paths", "question_6", "question_6_contract_paths"]
        }
      ]
    },
    ".sql": {
      "engine": "regex",
      "rules": [
        {
          "label": "distinct contract count",
          "pattern": "COUNT\\s*\\(\\s*DISTINCT"
        },
        {
          "label": "status_taken filter",
          "pattern": "status_taken"
        },
        {
          "label": "task join",
          "pattern": "WorkflowTaskInfo|filter_code|xmlflow_status"
        },
        {
          "label": "processing CTE or pairing",
          "pattern": "WITH|input|output|processing"
        }
      ]
    },
    ".xsl": {
      "engine": "regex",
      "rules": [
        {
          "label": "futures filter",
          "pattern": "PutCall|Future"
        },
        {
          "label": "contract code filter",
          "pattern": "ContractCode|GOVI|R186"
        },
        {
          "label": "murex output structure",
          "pattern": "scpr:|mp:date|bid1|ask1"
        },
        {
          "label": "market routing",
          "pattern": "ZA JSE|ZAR BD GOV"
        }
      ]
    },
    ".xslt": {
      "engine": "regex",
      "inherit_from": ".xsl"
    }
  }
}

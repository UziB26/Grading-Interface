{
  "assignment_id": "technical_assignment_2024",
  "title": "Technical Assignment 2024",
  "version": "1.0",
  "benchmark_dir": "benchmark_files",
  "submissions_dir": "student_submissions",
  "reports_dir": "outputs/grading_reports",
  "allowed_extensions": [
    ".csv",
    ".py",
    ".sql",
    ".xsl",
    ".xslt",
    ".xml",
